assets/
# But do track skill assets (`.agents/skills/*/assets/...`); the top-level
# `assets/` ignore was too broad and was also masking the per-skill
# config symlinks.
!.agents/skills/*/assets/
!.agents/skills/*/assets/**

# Per-resolution / per-mode smoke configs paired with the verification
# drivers. Hardcoded output paths under sdg_test_output/ so they only
# work on the maintainer's machine.
configs/sdg/test_*.yaml

_*
# Local convenience symlinks for pipeline assets — point at user-specific
# scene / component USD source dirs outside the repo. Not part of the MR.
/assets
/scripts/procedural_board/assets
